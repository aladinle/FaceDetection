{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure (MSVC + vcpkg)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S", ".",
        "-B", "build",
        "-G", "Visual Studio 17 2022",
        "-A", "x64",
        "-DCMAKE_TOOLCHAIN_FILE=C:/vcpkg/scripts/buildsystems/vcpkg.cmake"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "CMake Build (Release)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "build",
        "--config", "Release"
      ],
      "group": "build",
      "dependsOn": "CMake Configure (MSVC + vcpkg)",
      "problemMatcher": ["$msCompile"]
    },
    {
      "label": "CMake Build (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build", "build",
        "--config", "Debug"
      ],
      "group": "build",
      "dependsOn": "CMake Configure (MSVC + vcpkg)",
      "problemMatcher": ["$msCompile"]
    }
  ]
}